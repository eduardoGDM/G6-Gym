# Modelo de variáveis de ambiente do frontend.
# Copie para `.env.local` (ignorado pelo git) para sobrescrever localmente.
# Apenas variáveis prefixadas com VITE_ são expostas ao bundle — nunca use segredos aqui.

# Origem do backend Laravel (sem barra final e sem /api).
VITE_API_URL=http://localhost:8000

# Timeout das requisições HTTP em milissegundos.
VITE_REQUEST_TIMEOUT=30000
